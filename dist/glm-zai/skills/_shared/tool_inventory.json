{
  "schema_version": "2026-06-15",
  "evidence_root": "reports/",
  "tool_classes": [
    "core-local",
    "mcp-local",
    "optional-cloud",
    "custom-script",
    "planned"
  ],
  "reporting_states": [
    "Ran",
    "Skipped",
    "Planned",
    "Manual"
  ],
  "tools": [
    {
      "id": "classify-product-type",
      "class": "custom-script",
      "status": "implemented",
      "skills": ["senior-ui-ux-orchestrator"],
      "path": "senior-ui-ux-orchestrator/scripts/classify_product_type.py",
      "command": "python3 scripts/classify_product_type.py --input \"$PROMPT\" --out reports/intake.json",
      "inputs": ["prompt text"],
      "outputs": ["reports/intake.json"],
      "privacy": "local-only",
      "failure_behavior": "fall back to manual classification and report the script failure"
    },
    {
      "id": "validate-tool-inventory",
      "class": "custom-script",
      "status": "implemented",
      "skills": ["senior-ui-ux-orchestrator", "_shared"],
      "path": "senior-ui-ux-orchestrator/scripts/validate_tool_inventory.py",
      "command": "python3 scripts/validate_tool_inventory.py --inventory ../../shared/tool_inventory.json --out reports/tool-inventory-check.json",
      "inputs": ["tool inventory JSON"],
      "outputs": ["reports/tool-inventory-check.json"],
      "privacy": "local-only",
      "failure_behavior": "block production readiness until inventory errors are fixed"
    },
    {
      "id": "webapp-state-coverage",
      "class": "custom-script",
      "status": "implemented",
      "skills": ["webapp-ui-skill"],
      "path": "webapp-ui-skill/scripts/check_state_coverage.ts",
      "command": "node scripts/check_state_coverage.ts --root \"$PROJECT_ROOT\" --out reports/state-coverage.json",
      "inputs": ["project root"],
      "outputs": ["reports/state-coverage.json"],
      "privacy": "local-project-files",
      "failure_behavior": "report missing evidence and continue with manual state review"
    },
    {
      "id": "webapp-visual-smoke",
      "class": "custom-script",
      "status": "implemented",
      "skills": ["webapp-ui-skill", "ux-audit-skill"],
      "path": "webapp-ui-skill/scripts/visual_smoke_test.mjs",
      "command": "node scripts/visual_smoke_test.mjs --url \"$URL\" --out reports/visual-smoke",
      "inputs": ["url"],
      "outputs": ["reports/visual-smoke/summary.json"],
      "privacy": "local-url-or-public-url",
      "failure_behavior": "continue with manual visual review and report missing screenshots"
    },
    {
      "id": "marketing-metadata-lint",
      "class": "custom-script",
      "status": "implemented",
      "skills": ["marketing-site-skill"],
      "path": "marketing-site-skill/scripts/lint_metadata.py",
      "command": "python3 scripts/lint_metadata.py --root \"$PROJECT_ROOT\" --out reports/metadata.json",
      "inputs": ["project root containing HTML or app files"],
      "outputs": ["reports/metadata.json"],
      "privacy": "local-project-files",
      "failure_behavior": "report metadata gaps and continue with manual SEO/UX review"
    },
    {
      "id": "marketing-responsive-smoke",
      "class": "custom-script",
      "status": "implemented",
      "skills": ["marketing-site-skill", "ux-audit-skill"],
      "path": "marketing-site-skill/scripts/responsive_smoke_test.mjs",
      "command": "node scripts/responsive_smoke_test.mjs --url \"$URL\" --out reports/visual-smoke",
      "inputs": ["url"],
      "outputs": ["reports/visual-smoke/summary.json"],
      "privacy": "local-url-or-public-url",
      "failure_behavior": "continue with manual responsive review and report missing screenshots"
    },
    {
      "id": "figma-mcp-context",
      "class": "mcp-local",
      "status": "available-when-connected",
      "skills": ["senior-ui-ux-orchestrator", "senior-figma-orchestrator", "figma-context-reader", "figma-design-to-code-bridge", "webapp-ui-skill", "marketing-site-skill", "ux-audit-skill", "design-critic-skill"],
      "path": "connected Figma MCP tools",
      "command": "Use Figma MCP only when the user provides a Figma URL or connected frame context.",
      "inputs": ["figma url or connected frame context"],
      "outputs": ["frame metadata", "screenshot or design context when available"],
      "privacy": "provided-design-context-only",
      "failure_behavior": "fall back to local screenshots, code review, or manual critique"
    },
    {
      "id": "figma-mcp-canvas-write",
      "class": "mcp-local",
      "status": "available-when-connected",
      "skills": ["senior-figma-orchestrator", "figma-canvas-editor", "figma-design-system-sync", "figma-apply-effects"],
      "path": "connected Figma MCP write-to-canvas tools",
      "command": "Invoke the installed figma:figma-use skill before use_figma; mutate only scoped Figma targets and read metadata back afterward.",
      "inputs": ["figma target file/page/node", "explicit mutation scope"],
      "outputs": ["updated Figma nodes", "readback metadata or screenshot/export evidence"],
      "privacy": "provided-design-context-only",
      "failure_behavior": "do not claim mutation; fall back to manual Figma steps or local implementation"
    },
    {
      "id": "figma-code-to-canvas",
      "class": "mcp-local",
      "status": "available-when-connected",
      "skills": ["senior-figma-orchestrator", "figma-code-to-canvas"],
      "path": "connected Figma generated-design/code-to-canvas tools",
      "command": "Use only when the current Figma MCP/client supports generated design or code-to-canvas for the target URL/app.",
      "inputs": ["reachable URL or browser context", "target Figma file/page", "privacy approval when non-public data is sent"],
      "outputs": ["generated editable Figma layers", "reconciliation report"],
      "privacy": "external-transfer-possible-requires-classification",
      "failure_behavior": "fall back to manual canvas rebuild plan and source screenshot evidence"
    },
    {
      "id": "figma-code-connect",
      "class": "mcp-local",
      "status": "available-when-connected",
      "skills": ["figma-design-to-code-bridge", "figma-design-system-sync"],
      "path": "installed figma:figma-code-connect skill and local Code Connect files",
      "command": "Use the installed figma:figma-code-connect skill for Code Connect-specific create/review work.",
      "inputs": ["Figma component context", "local code component files"],
      "outputs": ["Code Connect mapping files or review notes"],
      "privacy": "local-code-and-provided-design-context",
      "failure_behavior": "produce a component mapping gap report instead of claiming Code Connect coverage"
    },
    {
      "id": "figma-effects-api",
      "class": "mcp-local",
      "status": "available-when-connected",
      "skills": ["figma-apply-effects", "figma-design-system-sync"],
      "path": "Figma Plugin API-compatible effects through connected Figma tools",
      "command": "Read node.effects, apply compatible effect objects or styles, bind supported variables, and read node.effects back.",
      "inputs": ["selected Figma node", "effect recipe or style", "optional variable names"],
      "outputs": ["updated effects array or style ID", "effects readback report"],
      "privacy": "provided-design-context-only",
      "failure_behavior": "runtime-gate advanced effects; fall back to core shadow/blur approximation or manual instructions"
    },
    {
      "id": "figma-asset-export",
      "class": "mcp-local",
      "status": "available-when-connected",
      "skills": ["figma-assets-manager"],
      "path": "connected Figma asset export/download tools",
      "command": "Export selected nodes/assets in scoped formats and produce an asset manifest.",
      "inputs": ["selected nodes or Figma asset references", "formats and scales"],
      "outputs": ["exported assets", "asset manifest"],
      "privacy": "provided-design-context-only",
      "failure_behavior": "request manual export or fallback assets and report skipped export"
    },
    {
      "id": "playwright-browser-check",
      "class": "core-local",
      "status": "project-dependent",
      "skills": ["webapp-ui-skill", "marketing-site-skill", "ux-audit-skill"],
      "path": "project Playwright setup or bundled browser tooling",
      "command": "npx playwright test or a project-specific Playwright command when the project already provides it",
      "inputs": ["reachable local or public URL", "project test config"],
      "outputs": ["Playwright report or screenshots"],
      "privacy": "local-url-or-public-url",
      "failure_behavior": "report skipped browser evidence and continue with available static/manual review"
    },
    {
      "id": "cursor-reveal-smoke",
      "class": "custom-script",
      "status": "implemented",
      "skills": ["cursor-reveal-hero"],
      "path": "cursor-reveal-hero/scripts/smoke-check-reveal.mjs",
      "command": "node scripts/smoke-check-reveal.mjs --url \"$URL\" --screenshot reports/reveal-smoke.png",
      "inputs": ["reachable local or public URL"],
      "outputs": ["screenshot", "terminal smoke summary"],
      "privacy": "local-url-or-public-url",
      "failure_behavior": "inspect manually and report missing browser evidence"
    },
    {
      "id": "image-layer-alignment-report",
      "class": "custom-script",
      "status": "implemented",
      "skills": ["image-layer-alignment-validator", "cursor-reveal-hero"],
      "path": "image-layer-alignment-validator/scripts/compare_layers.py",
      "command": "python3 scripts/compare_layers.py --base \"$BASE\" --reveal \"$REVEAL\" --out reports/image-alignment",
      "inputs": ["base image", "reveal image"],
      "outputs": ["alignment-report.md", "alignment-metrics.json", "annotated images", "overlay and difference map"],
      "privacy": "local-image-files",
      "failure_behavior": "return inconclusive/manual visual review and do not tune reveal based on unverified alignment"
    },
    {
      "id": "axe-accessibility-scan",
      "class": "planned",
      "status": "planned",
      "skills": ["webapp-ui-skill", "ux-audit-skill"],
      "path": "ux-audit-skill/scripts/axe_scan.mjs",
      "command": "planned: node scripts/axe_scan.mjs --url \"$URL\" --out reports/a11y/axe.json",
      "inputs": ["url"],
      "outputs": ["reports/a11y/axe.json"],
      "privacy": "local-url-or-public-url",
      "failure_behavior": "cannot be used as evidence until implemented"
    },
    {
      "id": "lighthouse-ci-wrapper",
      "class": "planned",
      "status": "planned",
      "skills": ["marketing-site-skill", "ux-audit-skill"],
      "path": "marketing-site-skill/scripts/lighthouse_ci_wrapper.mjs",
      "command": "planned: node scripts/lighthouse_ci_wrapper.mjs --url \"$URL\" --out reports/lighthouse/lhci.json",
      "inputs": ["url"],
      "outputs": ["reports/lighthouse/lhci.json"],
      "privacy": "local-url-or-public-url",
      "failure_behavior": "cannot be used as evidence until implemented"
    },
    {
      "id": "v0-platform-api",
      "class": "optional-cloud",
      "status": "approval-gated",
      "skills": ["webapp-ui-skill", "marketing-site-skill"],
      "path": "external service, no bundled wrapper in MVP",
      "command": "Use only after explicit user approval; record service, data sent, purpose, and local fallback.",
      "inputs": ["approved brief", "optional approved source context"],
      "outputs": ["cloud draft or generated artifact"],
      "privacy": "external-upload-requires-approval",
      "failure_behavior": "fall back to local implementation and report cloud step as skipped"
    }
  ]
}
