{
  "name": "@mlllm/ui-ux-agent-skill-system",
  "version": "0.2.0",
  "description": "Vendor-neutral core UI/UX agent skill system with optional vendor-specific adapters and integrations.",
  "license": "Apache-2.0",
  "author": "Sergey Kostenchuk",
  "homepage": "https://github.com/sergekostenchuk/ui-ux-agent-skill-system#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sergekostenchuk/ui-ux-agent-skill-system.git"
  },
  "bugs": {
    "url": "https://github.com/sergekostenchuk/ui-ux-agent-skill-system/issues"
  },
  "bin": {
    "uiux-skills": "bin/uiux-skills.js"
  },
  "files": [
    "adapters/",
    "bin/",
    "core/",
    "dist/",
    "docs/",
    "evals/",
    "reports/package-validation.md",
    "scripts/",
    "CHANGELOG.md",
    "FEATURE-PREPARATION.md",
    "LICENSE",
    "NOTICE",
    "README.md",
    "SECURITY.md",
    "TASK-PLAN.md"
  ],
  "keywords": [
    "ai",
    "agent",
    "skills",
    "ui",
    "ux",
    "codex",
    "claude",
    "gemini",
    "qwen",
    "figma",
    "seo",
    "llm"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:adapters": "python3 scripts/build_adapters.py . --out dist",
    "check:dist": "python3 scripts/check_dist_sync.py .",
    "check:eval-contracts": "python3 scripts/check_eval_contracts.py",
    "check:freshness": "python3 scripts/check_freshness.py .",
    "eval": "python3 scripts/run_evals.py . --out reports/eval-results.json",
    "lint": "python3 scripts/lint_publication_package.py .",
    "test:evidence": "python3 scripts/test_evidence_validator.py",
    "validate:evidence": "python3 scripts/validate_evidence_report.py tests/fixtures/evidence/valid.md",
    "prepack": "python3 scripts/lint_publication_package.py ."
  }
}
